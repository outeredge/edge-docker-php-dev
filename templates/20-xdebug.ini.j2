[xdebug]
{% if XDEBUG_ENABLE == 'On' %}
zend_extension = xdebug.so
{% else %}
;zend_extension = xdebug.so
{% endif %}

xdebug.mode = debug,profile
xdebug.start_with_request = trigger
xdebug.output_dir = {{ WEB_ROOT }}
xdebug.use_compression = true
xdebug.max_nesting_level = 300
xdebug.cli_color = 1
xdebug.filename_format = %f
xdebug.client_port = 9000

{% if XDEBUG_HOST is defined and XDEBUG_HOST %}
xdebug.client_host = {{ XDEBUG_HOST }}
{% endif %}
